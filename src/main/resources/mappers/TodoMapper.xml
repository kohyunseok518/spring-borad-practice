<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.org.spring_board_project.mapper.TodoMapper">

    <resultMap id="attachmentMap" type="com.org.spring_board_project.domain.TodoAttachmentVO" autoMapping="false">
        <id column="ano" property="ano"/>
        <result column="tno" property="tno"/>
        <result column="filename" property="filename"/>
        <result column="path" property="path"/>
        <result column="content_type" property="contentType"/>
        <result column="size" property="size"/>
        <result column="reg_date" property="regDate"/>
    </resultMap>
    
    <resultMap id="todoMap" type="com.org.spring_board_project.domain.TodoVO" autoMapping="false">
        <id column="tno" property="tno"/>
        <result column="title" property="title"/>
        <result column="dueDate" property="dueDate"/>
        <result column="writer" property="writer"/>
        <result column="finished" property="finished"/>

        <collection property="attaches" resultMap="attachmentMap"/>
    </resultMap>

    <select id="getTime" resultType="string">
        select now()
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="tno">
        insert into tbl_todo(title, dueDate, writer) values ( #{title}, #{dueDate}, #{writer})
    </insert>

    <insert id="insertAttachment">
        insert into tbl_todo_attachment (filename, path, content_type, size, tno)
        values (#{filename}, #{path}, #{contentType}, #{size}, #{tno})
    </insert>

    <select id="getAttachment" resultType="com.org.spring_board_project.domain.TodoAttachmentVO">
        select ano, tno, filename, path from tbl_todo_attachment where ano = #{ano}
    </select>

    <select id="selectAll"
            resultType="com.org.spring_board_project.domain.TodoVO">
        select * from tbl_todo order by tno asc;
    </select>

    <select id="selectOne" resultMap="todoMap">
        SELECT
            t.tno, t.title, t.dueDate, t.writer, t.finished,
            a.ano, a.filename, a.path, a.content_type, a.size, a.reg_date
        FROM tbl_todo t
        LEFT OUTER JOIN tbl_todo_attachment a
            ON t.tno = a.tno
        WHERE t.tno = #{tno}
        ORDER BY a.ano ASC
    </select>

    <delete id="delete">
        delete from tbl_todo where tno = #{tno}
    </delete>

    <update id="update">
        update tbl_todo set title = #{title}, dueDate = #{dueDate}, finished = #{finished} where tno = #{tno}
    </update>

    <select id="selectList" resultType="com.org.spring_board_project.domain.TodoVO">
        select * from tbl_todo
        <where>
            <if test="types != null and types.length > 0">
                <foreach collection="types" item="type" open="(" close=") " separator=" OR ">
                    <if test="type == 't'.toString()">
                        title like concat('%', #{keyword}, '%')
                    </if>
                    <if test="type == 'w'.toString()">
                        writer like concat('%', #{keyword}, '%')
                    </if>
                </foreach>
            </if>

            <if test="finished">
                <trim prefix="and">
                    finished = 1
                </trim>
            </if>

            <if test="from != null and to != null">
                <trim prefix="and">
                    dueDate between #{from} and #{to}
                </trim>
            </if>
        </where>
        order by tno desc limit #{skip}, #{size}
    </select>

    <select id="getCount" resultType="int">
        select count(tno) from tbl_todo
        <where>
            <if test="types != null and types.length > 0">
                <foreach collection="types" item="type" open="(" close=") " separator=" OR ">
                    <if test="type == 't'.toString()">
                        title like concat('%', #{keyword}, '%')
                    </if>
                    <if test="type == 'w'.toString()">
                        writer like concat('%', #{keyword}, '%')
                    </if>
                </foreach>
            </if>

            <if test="finished">
                <trim prefix="and">
                    finished = 1
                </trim>
            </if>

            <if test="from != null and to != null">
                <trim prefix="and">
                    dueDate between #{from} and #{to}
                </trim>
            </if>
        </where>
    </select>
</mapper>